<Window x:Class="ProviderPilot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ProviderPilot"
        Icon="icon.ico"
        Width="1280"
        Height="780"
        MinHeight="680"
        Background="{DynamicResource Canvas}"
        TextElement.Foreground="{DynamicResource Ink}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="228"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource Sidebar}" BorderBrush="{DynamicResource SidebarLine}" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,16">
                    <TextBlock Text="ProviderPilot" Foreground="{DynamicResource Ink}" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="Switch Claude Code and Codex across inference providers." Foreground="{DynamicResource MutedInk}" FontSize="13" Margin="0,6,0,0"/>

                    <StackPanel Margin="0,24,0,0">
                        <Button x:Name="ClaudeNavButton" Style="{StaticResource SidebarButton}" Content="Claude Code" Click="ClaudeNav_Click" Margin="0,0,0,8"/>
                        <Button x:Name="CodexNavButton" Style="{StaticResource SidebarButton}" Content="Codex" Click="CodexNav_Click" Margin="0,0,0,8"/>
                        <Button x:Name="ProvidersNavButton" Style="{StaticResource SidebarButton}" Content="Inference Providers" Click="ProvidersNav_Click"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="18">
                    <Button Content="Preview" Style="{StaticResource AccentButton}" Click="Preview_Click" Margin="0,0,0,8"/>
                    <Button Content="Save and Enable" Style="{StaticResource PrimaryButton}" Click="Apply_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PanelCard}" Padding="18" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="HeaderTitle" Text="Claude Code" FontSize="25" FontWeight="SemiBold"/>
                        <TextBlock x:Name="HeaderSubtitle" Text="Large, medium, and small model routing with separate inference providers." Foreground="{StaticResource MutedInk}" Margin="0,5,0,0"/>
                    </StackPanel>
                    <Border x:Name="HealthBadge" Grid.Column="1" Background="{StaticResource WarnSoft}" Padding="12,7" CornerRadius="6" VerticalAlignment="Center">
                        <TextBlock x:Name="HealthText" Text="Review" Foreground="{StaticResource Warn}" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <ScrollViewer x:Name="ClaudePage" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="{StaticResource BrandSoft}" BorderBrush="{StaticResource BrandSoftBorder}" BorderThickness="1" CornerRadius="10" Padding="18" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Claude Code Integration" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                    <TextBlock Text="Choose which provider handles each Claude model class. Models are selected here, not inside provider settings." Foreground="{StaticResource MutedInk}" FontSize="12" Margin="0,5,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <ToggleButton x:Name="ClaudeEnabledBox" Content="Enabled" Style="{StaticResource ToggleSwitchStyle}" Checked="AppConfig_Changed" Unchecked="AppConfig_Changed" Margin="0,0,16,0"/>
                                    <ToggleButton x:Name="ClaudeGatewayBox" Content="Gateway mode" Style="{StaticResource ToggleSwitchStyle}" Checked="AppConfig_Changed" Unchecked="AppConfig_Changed" Margin="0,0,16,0"/>
                                    <ToggleButton x:Name="SetEnvBox" Content="Set env keys" Style="{StaticResource ToggleSwitchStyle}" Checked="AppConfig_Changed" Unchecked="AppConfig_Changed"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource PanelCard}" Padding="18" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Large Model" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="Opus" Foreground="{StaticResource MutedInk}" FontSize="12" Margin="0,3,0,14"/>
                                    <TextBlock Style="{StaticResource LabelText}" Text="Provider"/>
                                    <ComboBox x:Name="ClaudeOpusProviderBox" SelectionChanged="ClaudeSlotProvider_Changed" Margin="0,0,0,12"/>
                                    <TextBlock Style="{StaticResource LabelText}" Text="Model"/>
                                    <ComboBox x:Name="ClaudeOpusBox" IsEditable="True" SelectionChanged="AppConfig_Changed"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource PanelCard}" Padding="18" Margin="5,0">
                                <StackPanel>
                                    <TextBlock Text="Medium Model" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="Sonnet" Foreground="{StaticResource MutedInk}" FontSize="12" Margin="0,3,0,14"/>
                                    <TextBlock Style="{StaticResource LabelText}" Text="Provider"/>
                                    <ComboBox x:Name="ClaudeSonnetProviderBox" SelectionChanged="ClaudeSlotProvider_Changed" Margin="0,0,0,12"/>
                                    <TextBlock Style="{StaticResource LabelText}" Text="Model"/>
                                    <ComboBox x:Name="ClaudeSonnetBox" IsEditable="True" SelectionChanged="AppConfig_Changed"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource PanelCard}" Padding="18" Margin="10,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Small Model" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="Haiku / background" Foreground="{StaticResource MutedInk}" FontSize="12" Margin="0,3,0,14"/>
                                    <TextBlock Style="{StaticResource LabelText}" Text="Provider"/>
                                    <ComboBox x:Name="ClaudeHaikuProviderBox" SelectionChanged="ClaudeSlotProvider_Changed" Margin="0,0,0,12"/>
                                    <TextBlock Style="{StaticResource LabelText}" Text="Model"/>
                                    <ComboBox x:Name="ClaudeHaikuBox" IsEditable="True" SelectionChanged="AppConfig_Changed"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource PanelCard}" Padding="18" Margin="0,0,7,0">
                                <StackPanel>
                                    <TextBlock Text="Default Model" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                    <TextBlock Style="{StaticResource LabelText}" Text="Provider"/>
                                    <ComboBox x:Name="ClaudeDefaultProviderBox" SelectionChanged="ClaudeSlotProvider_Changed" Margin="0,0,0,12"/>
                                    <TextBlock Style="{StaticResource LabelText}" Text="Model"/>
                                    <ComboBox x:Name="ClaudeDefaultBox" IsEditable="True" SelectionChanged="AppConfig_Changed"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource PanelCard}" Padding="18" Margin="7,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Subagent Model" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                    <TextBlock Style="{StaticResource LabelText}" Text="Provider"/>
                                    <ComboBox x:Name="ClaudeSubagentProviderBox" SelectionChanged="ClaudeSlotProvider_Changed" Margin="0,0,0,12"/>
                                    <TextBlock Style="{StaticResource LabelText}" Text="Model"/>
                                    <ComboBox x:Name="ClaudeSubagentBox" IsEditable="True" SelectionChanged="AppConfig_Changed"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="CodexPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="{StaticResource BrandSoft}" BorderBrush="{StaticResource BrandSoftBorder}" BorderThickness="1" CornerRadius="10" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Codex Configuration" FontSize="20" FontWeight="SemiBold"/>
                                <TextBlock Text="Select Codex provider and model here. Reasoning stays controlled by Codex." Foreground="{DynamicResource MutedInk}" FontSize="12" Margin="0,5,0,16"/>
                                <ToggleButton x:Name="CodexEnabledBox" Content="Update Codex config.toml" Style="{StaticResource ToggleSwitchStyle}" Checked="AppConfig_Changed" Unchecked="AppConfig_Changed" Margin="0,0,0,14"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="280"/>
                                        <ColumnDefinition Width="420"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Style="{StaticResource LabelText}" Text="Provider"/>
                                        <ComboBox x:Name="CodexProviderBox" SelectionChanged="CodexProvider_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Style="{StaticResource LabelText}" Text="Model"/>
                                        <ComboBox x:Name="CodexModelBox" IsEditable="True" SelectionChanged="AppConfig_Changed"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid x:Name="ProviderPage" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="230"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource PanelCard}" Padding="14" Margin="0,0,14,0">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Providers" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="Inference only" Foreground="{StaticResource MutedInk}" FontSize="12" Margin="0,3,0,12"/>
                                <Button Content="Add Provider" Style="{StaticResource AccentButton}" Click="AddProvider_Click" Margin="0,0,0,8"/>
                                <Button Content="Duplicate Provider" Click="DuplicateProvider_Click" Margin="0,0,0,8"/>
                                <Button Content="Delete Provider" Style="{StaticResource DangerButton}" Click="DeleteProvider_Click" Margin="0,0,0,12"/>
                            </StackPanel>
                            <ListBox x:Name="ProviderList"
                                     SelectionChanged="ProviderList_SelectionChanged"
                                     BorderBrush="{StaticResource Line}"
                                     BorderThickness="1"
                                     Background="Transparent"
                                     Foreground="{StaticResource Ink}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                            <TextBlock Text="{Binding ProviderKind}" Foreground="{StaticResource MutedInk}" FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="0,0,14,0">
                        <Border Style="{StaticResource PanelCard}" Padding="18">
                            <StackPanel>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Provider Details" FontSize="20" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="ModelCatalogText" Text="Load provider models after adding the provider key." Foreground="{StaticResource MutedInk}" FontSize="12" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Load Models" Click="LoadModels_Click" VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Style="{StaticResource LabelText}" Text="Provider name"/>
                                        <TextBox x:Name="NameBox" TextChanged="ProviderEditor_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Style="{StaticResource LabelText}" Text="Preset"/>
                                        <ComboBox x:Name="ProviderKindBox" SelectionChanged="ProviderKindBox_SelectionChanged"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Style="{StaticResource LabelText}" Text="API key environment variable"/>
                                <TextBox x:Name="AuthEnvBox" TextChanged="ProviderEditor_Changed" LostFocus="MaybeAutoLoadModels_Event" Margin="0,0,0,12"/>

                                <TextBlock Style="{StaticResource LabelText}" Text="API key value"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <PasswordBox x:Name="ApiKeyBox" PasswordChanged="ApiKeyBox_PasswordChanged" LostFocus="MaybeAutoLoadModels_Event"/>
                                    <TextBox x:Name="ApiKeyRevealBox" Visibility="Collapsed" TextChanged="ApiKeyRevealBox_TextChanged"/>
                                    <Button Grid.Column="1" Content="Copy" Click="CopyApiKey_Click" Margin="8,0,0,0"/>
                                    <Button Grid.Column="2" x:Name="ToggleApiKeyButton" Content="See" Click="ToggleApiKey_Click" Margin="8,0,0,0"/>
                                </Grid>

                                <TextBlock Style="{StaticResource LabelText}" Text="Base URL"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="BaseUrlBox" TextChanged="ProviderEditor_Changed" LostFocus="MaybeAutoLoadModels_Event"/>
                                    <Button Grid.Column="1" Content="Copy" Click="CopyBaseUrl_Click" Margin="8,0,0,0"/>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Style="{StaticResource LabelText}" Text="Wire API"/>
                                        <ComboBox x:Name="WireApiBox" SelectionChanged="ProviderEditor_Changed">
                                            <ComboBoxItem Content="responses"/>
                                            <ComboBoxItem Content="chat"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="AutoloadModelsBox" Content="Auto-load model catalog after URL/key changes" Style="{StaticResource ToggleSwitchStyle}" Checked="ProviderEditor_Changed" Unchecked="ProviderEditor_Changed" VerticalAlignment="Bottom" Margin="8,0,0,8"/>
                                </Grid>

                                <TextBlock Style="{StaticResource LabelText}" Text="Extra HTTP headers, one KEY=value per line"/>
                                <TextBox x:Name="HeadersBox" AcceptsReturn="True" Height="72" TextChanged="ProviderEditor_Changed" Margin="0,0,0,12"/>

                                <TextBlock Style="{StaticResource LabelText}" Text="Query params, one KEY=value per line"/>
                                <TextBox x:Name="QueryBox" AcceptsReturn="True" Height="54" TextChanged="ProviderEditor_Changed"/>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>

                    <Border Grid.Column="2" Style="{StaticResource PanelCard}" Padding="18">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Models Available" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="Provider catalog only" Foreground="{StaticResource MutedInk}" FontSize="12" Margin="0,3,0,10"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Content="Star" Click="StarModel_Click" Margin="0,0,8,0"/>
                                    <Button Content="Delete" Style="{StaticResource DangerButton}" Click="DeleteModel_Click"/>
                                </StackPanel>
                            </StackPanel>
                            <ListBox x:Name="ProviderModelsList" Background="Transparent" Foreground="{StaticResource Ink}" BorderBrush="{StaticResource Line}" BorderThickness="1"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="2" Background="{StaticResource SuccessSoft}" BorderBrush="{StaticResource Success}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,14,0,0">
                <TextBlock x:Name="StatusText" Foreground="{StaticResource Success}" Text="Ready. Configure Claude Code, Codex, and inference providers, then save and enable."/>
            </Border>
        </Grid>
    </Grid>
</Window>
